---
import { sanityClient } from '../sanity/lib/client.js';

let settings = null;
try {
  settings = await sanityClient.fetch(`*[_type == "settings"][0]`);
} catch (error) {
  console.error("Error fetching site settings:", error);
}

const footerText = settings?.footerText || "Bringing the pure essence of the Karakoram range to your doorstep. Sustainable, wild-crafted, and authentic.";
const socials = settings?.socials || [
  { platform: "Instagram", url: "#" },
  { platform: "Twitter", url: "#" },
  { platform: "Facebook", url: "#" }
];
const copyright = settings?.copyright || `© ${new Date().getFullYear()} Skardu Essence. All rights reserved.`;
const location = settings?.location || "Handcrafted in Skardu, Pakistan.";
---
<footer class="bg-canvas-night-soft py-16 px-6 md:px-12 border-t border-hairline-on-dark">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
    <div class="md:col-span-2">
      <h2 class="text-xl font-display font-bold mb-4">{settings?.title || "Skardu Essence"}</h2>
      <p class="text-on-primary-mute max-w-sm mb-6">
        {footerText}
      </p>
      <div class="flex gap-4">
        {socials.map(social => (
          <a href={social.url} target="_blank" rel="noopener noreferrer" class="hover:text-brand-gold transition-colors">{social.platform}</a>
        ))}
      </div>
    </div>
    
    <div>
      <h3 class="font-display text-[12px] tracking-[1.17px] uppercase mb-4">Shop</h3>
      <ul class="space-y-2 text-[13px] text-on-primary-mute">
        <li><a href="/shop" class="hover:text-on-primary transition-colors">All Products</a></li>
        <li><a href="/shop?category=Supplements" class="hover:text-on-primary transition-colors">Supplements</a></li>
        <li><a href="/shop?category=Food" class="hover:text-on-primary transition-colors">Wild Food</a></li>
      </ul>
    </div>

    <div>
      <h3 class="font-display text-[12px] tracking-[1.17px] uppercase mb-4">Company</h3>
      <ul class="space-y-2 text-[13px] text-on-primary-mute">
        <li><a href="/about" class="hover:text-on-primary transition-colors">Our Story</a></li>
        <li><a href="/contact" class="hover:text-on-primary transition-colors">Contact</a></li>
        <li><a href="/terms" class="hover:text-on-primary transition-colors">Terms of Service</a></li>
      </ul>
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-hairline-on-dark flex flex-col md:flex-row justify-between items-center gap-4 text-[12px] text-on-primary-mute uppercase tracking-widest">
    <p>{copyright}</p>
    <p>{location}</p>
  </div>
</footer>
