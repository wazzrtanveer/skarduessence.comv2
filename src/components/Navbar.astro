---
import { ShoppingBag } from '@lucide/astro';
---

<nav id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-300 px-6 py-8 md:px-12">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <div class="flex-1 hidden md:flex gap-8">
      <a href="/" class="nav-link">Home</a>
      <a href="/shop" class="nav-link">Shop</a>
    </div>

    <div class="flex-shrink-0 text-center">
      <a href="/" class="text-xl md:text-2xl font-display font-bold tracking-[2px] md:tracking-[4px] uppercase">
        Skardu Essence
      </a>
    </div>

    <div class="flex-1 flex justify-end items-center gap-4 md:gap-8">
      <div class="hidden md:flex gap-8">
        <a href="/about" class="nav-link">About</a>
        <a href="/contact" class="nav-link">Contact</a>
      </div>
      
      <a href="/cart" class="relative group" aria-label="View Cart">
        <ShoppingBag class="w-6 h-6 hover:opacity-70 transition-opacity duration-300" aria-hidden="true" />
        <span id="cart-count" class="absolute -top-2 -right-2 bg-brand-gold text-ink text-[10px] font-bold rounded-full w-4 h-4 flex items-center justify-center hidden" aria-live="polite">0</span>
      </a>

      <!-- Mobile Menu Toggle -->
      <button id="menu-toggle" class="md:hidden" aria-label="Open Menu">
        <div class="w-6 h-0.5 bg-current mb-1.5"></div>
        <div class="w-6 h-0.5 bg-current"></div>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-canvas-night z-50 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-500">
    <button id="menu-close" class="absolute top-8 right-8 text-3xl" aria-label="Close Menu">&times;</button>
    <a href="/" class="text-3xl font-display uppercase tracking-widest">Home</a>
    <a href="/shop" class="text-3xl font-display uppercase tracking-widest">Shop</a>
    <a href="/about" class="text-3xl font-display uppercase tracking-widest">About</a>
    <a href="/contact" class="text-3xl font-display uppercase tracking-widest">Contact</a>
  </div>
</nav>

<script>
  import { cartItems } from '../store/cart.js';

  const navbar = document.getElementById('navbar');
  const cartCount = document.getElementById('cart-count');
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  // Update cart count
  cartItems.subscribe(items => {
    const total = items.reduce((acc, item) => acc + item.quantity, 0);
    if (total > 0) {
      cartCount.innerText = total;
      cartCount.classList.remove('hidden');
    } else {
      cartCount.classList.add('hidden');
    }
  });

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar.classList.add('bg-canvas-night/90', 'backdrop-blur-md', 'py-4');
      navbar.classList.remove('py-8');
    } else {
      navbar.classList.remove('bg-canvas-night/90', 'backdrop-blur-md', 'py-4');
      navbar.classList.add('py-8');
    }
  });

  // Mobile menu
  menuToggle.addEventListener('click', () => {
    mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  });

  menuClose.addEventListener('click', () => {
    mobileMenu.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  });

  // Close menu on link click
  const mobileLinks = mobileMenu.querySelectorAll('a');
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    });
  });
</script>
