---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us">
  <div class="pt-32 pb-24 px-6 md:px-12 bg-canvas-night light:bg-canvas-light text-on-primary light:text-ink min-h-screen transition-colors duration-500">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
      <div>
        <h1 class="text-4xl md:text-6xl font-display font-bold mb-8 uppercase tracking-tight">Contact</h1>
        <p class="text-mute font-body mb-12">
          Have questions about our products or sourcing? We'd love to hear from you. Reach out through the form or visit us in Skardu.
        </p>
        
        <div class="space-y-8 uppercase text-[12px] font-bold tracking-widest">
          <div>
            <span class="text-brand-gold block mb-2">Location</span>
            <p>Aliabad Road, Skardu<br/>Gilgit-Baltistan, Pakistan</p>
          </div>
          <div>
            <span class="text-brand-gold block mb-2">Email</span>
            <p>hello@skarduessence.com</p>
          </div>
          <div>
            <span class="text-brand-gold block mb-2">Social</span>
            <p>@skarduessence</p>
          </div>
        </div>
      </div>

      <div class="card-surface p-8 rounded-sm">
        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
          <!-- Replace with your actual Web3Forms Access Key -->
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE">
          
          <div>
            <label class="block text-[10px] uppercase font-bold tracking-widest text-mute mb-2">Name</label>
            <input 
              type="text" 
              name="name" 
              required 
              class="w-full bg-black/10 dark:bg-black/10 light:bg-canvas-cool border border-hairline-on-dark light:border-hairline-on-light rounded-sm px-4 py-3 font-body focus:outline-none focus:border-brand-gold transition-colors"
            />
          </div>
          
          <div>
            <label class="block text-[10px] uppercase font-bold tracking-widest text-mute mb-2">Email</label>
            <input 
              type="email" 
              name="email" 
              required 
              class="w-full bg-black/10 dark:bg-black/10 light:bg-canvas-cool border border-hairline-on-dark light:border-hairline-on-light rounded-sm px-4 py-3 font-body focus:outline-none focus:border-brand-gold transition-colors"
            />
          </div>
          
          <div>
            <label class="block text-[10px] uppercase font-bold tracking-widest text-mute mb-2">Message</label>
            <textarea 
              name="message" 
              rows="5" 
              required 
              class="w-full bg-black/10 dark:bg-black/10 light:bg-canvas-cool border border-hairline-on-dark light:border-hairline-on-light rounded-sm px-4 py-3 font-body focus:outline-none focus:border-brand-gold transition-colors"
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full bg-brand-gold text-ink border-none">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
