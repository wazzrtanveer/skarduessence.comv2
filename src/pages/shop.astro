---
import Layout from '../layouts/Layout.astro';
import { products as localProducts } from '../data/products.js';
import { sanityClient, urlFor } from '../sanity/lib/client.js';

// Fetch products from Sanity
let products = [];
try {
  const sanityProducts = await sanityClient.fetch(`*[_type == "product"] | order(featured desc, name asc) {
    _id,
    name,
    description,
    price,
    image,
    category,
    featured,
    "id": slug.current
  }`);
  
  if (sanityProducts && sanityProducts.length > 0) {
    products = sanityProducts.map(p => ({
      ...p,
      image: p.image ? urlFor(p.image).url() : '/placeholder.png'
    }));
  } else {
    // Fallback to local data if Sanity is empty
    products = localProducts;
  }
} catch (error) {
  console.error("Error fetching from Sanity:", error);
  products = localProducts;
}

const categories = [...new Set(products.map(p => p.category))];
---

<Layout title="Shop">
  <div class="pt-32 pb-24 px-6 md:px-12 bg-canvas-night text-on-primary min-h-screen">
    <div class="max-w-7xl mx-auto">
      <header class="mb-16">
        <h1 class="text-4xl md:text-6xl font-display font-bold mb-4">The Collection</h1>
        <p class="text-mute max-w-2xl font-body">
          Explore our range of premium Himalayan products, ethically sourced and meticulously prepared for the discerning consumer.
        </p>
      </header>

      <!-- Category Filter & Search -->
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-8 mb-12 border-b border-hairline-on-dark pb-8">
        <div class="flex flex-wrap gap-6" id="category-filters">
          <button class="category-btn active uppercase text-[12px] font-bold tracking-widest hover:opacity-70 transition-opacity cursor-pointer text-brand-gold" data-category="all">All</button>
          {categories.map(category => (
            <button class="category-btn uppercase text-[12px] font-bold tracking-widest hover:opacity-70 transition-opacity cursor-pointer text-mute" data-category={category.toLowerCase()}>{category}</button>
          ))}
        </div>

        <div class="relative w-full md:w-64">
          <input 
            type="text" 
            id="product-search"
            placeholder="Search products..."
            class="w-full bg-canvas-night-soft border border-hairline-on-dark rounded-pill px-6 py-2 text-sm font-body focus:outline-none focus:border-brand-gold transition-colors text-on-primary"
          />
          <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-30 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-on-primary"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
        </div>
      </div>

      <!-- Product Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="product-grid">
        {products.map(product => (
          <div class="product-card group relative card-surface rounded-sm overflow-hidden flex flex-col h-full transition-all hover:shadow-xl" data-name={product.name.toLowerCase()} data-category={product.category.toLowerCase()}>
            <a href={`/product/${product.id}`} class="block aspect-square overflow-hidden">
              <img 
                src={product.image} 
                alt={product.name} 
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            </a>
            
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-display font-bold uppercase tracking-wider">{product.name}</h3>
                <span class="font-body font-bold text-brand-gold">Rs. {product.price.toLocaleString()}</span>
              </div>
              <p class="text-mute text-sm mb-6 flex-grow">{product.description}</p>
              
              <div class="mt-auto flex flex-col gap-2">
                <div class="grid grid-cols-2 gap-2">
                  <a href={`/product/${product.id}`} class="btn-primary w-full text-center text-[10px] py-3 px-0">Details</a>
                  <button 
                    class="btn-primary w-full text-center text-[10px] py-3 px-0 bg-brand-gold text-canvas-night border-brand-gold hover:bg-transparent hover:text-white buy-now-btn"
                    data-product={JSON.stringify(product)}
                  >
                    Shop Now
                  </button>
                </div>
                <button 
                  class="btn-secondary w-full add-to-cart-btn text-[10px] py-3"
                  data-product={JSON.stringify(product)}
                >
                  Quick Add to Cart
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <!-- No Results Message -->
      <div id="no-results" class="hidden py-24 text-center">
        <p class="text-mute font-body italic">No products found matching your search.</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { addToCart } from '../store/cart.js';

  // Add to Cart Logic
  const addButtons = document.querySelectorAll('.add-to-cart-btn');
  const buyButtons = document.querySelectorAll('.buy-now-btn');

  const handleAdd = (btn) => {
    const product = JSON.parse(btn.getAttribute('data-product'));
    addToCart(product);
    alert(`${product.name} added to cart!`);
  };

  const handleBuy = (btn) => {
    const product = JSON.parse(btn.getAttribute('data-product'));
    addToCart(product);
    window.location.href = '/cart';
  };

  addButtons.forEach(btn => btn.addEventListener('click', () => handleAdd(btn)));
  buyButtons.forEach(btn => btn.addEventListener('click', () => handleBuy(btn)));

  // Combined Filtering Logic
  const searchInput = document.getElementById('product-search') as HTMLInputElement;
  const categoryButtons = document.querySelectorAll('.category-btn');
  const productCards = document.querySelectorAll('.product-card');
  const noResults = document.getElementById('no-results');

  let activeCategory = 'all';
  let searchQuery = '';

  const filterProducts = () => {
    let hasMatches = false;

    productCards.forEach(card => {
      const el = card as HTMLElement;
      const name = el.dataset.name || '';
      const category = el.dataset.category || '';
      
      const matchesSearch = name.includes(searchQuery) || category.includes(searchQuery);
      const matchesCategory = activeCategory === 'all' || category === activeCategory;

      if (matchesSearch && matchesCategory) {
        el.style.display = 'flex';
        hasMatches = true;
      } else {
        el.style.display = 'none';
      }
    });

    if (hasMatches) {
      noResults?.classList.add('hidden');
    } else {
      noResults?.classList.remove('hidden');
    }
  };

  // Search Input Event
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase();
    filterProducts();
  });

  // Category Button Events
  categoryButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      activeCategory = el.dataset.category || 'all';

      // Update UI classes
      categoryButtons.forEach(b => {
        b.classList.remove('text-brand-gold');
        b.classList.add('text-mute');
      });
      el.classList.add('text-brand-gold');
      el.classList.remove('text-mute');

      filterProducts();
    });
  });
</script>
