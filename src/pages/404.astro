---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Essence Not Found">
  <section class="relative h-screen w-full flex items-center justify-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 z-0">
      <img 
        src="/mountains.jpg" 
        alt="Skardu Mountains" 
        class="w-full h-full object-cover opacity-30 grayscale"
      />
      <div class="absolute inset-0 bg-canvas-night/80"></div>
    </div>

    <div class="relative z-10 text-center px-6">
      <div class="mb-6">
        <h1 class="text-[120px] md:text-[200px] leading-none font-display font-bold text-brand-gold/20 tracking-tighter">
          404
        </h1>
        <div class="mt-[-40px] md:mt-[-70px]">
          <h2 class="text-3xl md:text-5xl font-display font-bold uppercase tracking-widest text-white">
            Path Unknown
          </h2>
          <div class="w-20 h-1 bg-brand-gold mx-auto mt-4 mb-8"></div>
        </div>
      </div>

      <p class="text-mute font-body text-lg md:text-xl max-w-md mx-auto mb-12 opacity-80 uppercase tracking-wider">
        The essence you seek has vanished into the mountain mist.
      </p>

      <div class="flex flex-col md:flex-row gap-6 justify-center">
        <a href="/" class="btn-primary min-w-[200px]">Return to Base</a>
        <a href="/shop" class="btn-secondary min-w-[200px]">Explore Treasures</a>
      </div>
    </div>
  </section>
</Layout>
