---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/products.js';

export function getStaticPaths() {
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
---

<Layout title={product.name}>
  <div class="pt-32 pb-24 px-6 md:px-12 bg-canvas-night text-on-primary min-h-screen">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <!-- Image Gallery -->
      <div class="md:sticky md:top-32">
        <div class="aspect-square rounded-sm overflow-hidden bg-canvas-night-soft border border-hairline-on-dark">
          <img 
            src={product.image} 
            alt={product.name} 
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <!-- Product Info -->
      <div class="flex flex-col gap-8">
        <div>
          <span class="text-[12px] font-bold tracking-[2px] uppercase text-brand-gold mb-4 block">
            {product.category}
          </span>
          <h1 class="text-4xl md:text-6xl font-display font-bold uppercase mb-4 tracking-tighter">
            {product.name}
          </h1>
          <p class="text-2xl font-body font-bold">
            Rs. {product.price.toLocaleString()}
          </p>
        </div>

        <div class="h-px bg-hairline-on-dark"></div>

        <div class="font-body text-mute leading-relaxed space-y-4">
          <p>{product.description}</p>
          <p>Sourced directly from the pristine valleys of Skardu, our {product.name} is a testament to the purity of nature. We ensure sustainable harvesting and traditional processing methods to preserve the maximum nutrient density and authentic flavor.</p>
        </div>

        <div class="flex flex-col gap-4 pt-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <button 
              id="add-to-cart-large"
              class="btn-secondary py-6 text-base"
              data-product={JSON.stringify(product)}
            >
              Add to Cart
            </button>
            <button 
              id="buy-now"
              class="btn-primary py-6 text-base bg-brand-gold text-canvas-night border-brand-gold hover:bg-transparent hover:text-white"
              data-product={JSON.stringify(product)}
            >
              Shop Now
            </button>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="p-4 border border-hairline-on-dark rounded-sm text-center">
              <span class="block text-[10px] uppercase font-bold tracking-widest text-mute mb-1">Origin</span>
              <span class="text-sm font-body">Skardu Valley</span>
            </div>
            <div class="p-4 border border-hairline-on-dark rounded-sm text-center">
              <span class="block text-[10px] uppercase font-bold tracking-widest text-mute mb-1">Purity</span>
              <span class="text-sm font-body">100% Organic</span>
            </div>
          </div>
        </div>

        <div class="mt-8 border-t border-hairline-on-dark pt-8">
          <details class="group py-4 border-b border-hairline-on-dark">
            <summary class="flex justify-between items-center cursor-pointer list-none uppercase text-[12px] font-bold tracking-widest">
              Sustainability & Ethics
              <span class="group-open:rotate-180 transition-transform">↓</span>
            </summary>
            <div class="pt-4 text-sm text-mute">
              We work directly with local communities in Skardu to ensure fair wages and sustainable harvesting practices that protect the fragile mountain ecosystem.
            </div>
          </details>
          <details class="group py-4 border-b border-hairline-on-dark">
            <summary class="flex justify-between items-center cursor-pointer list-none uppercase text-[12px] font-bold tracking-widest">
              Shipping & Returns
              <span class="group-open:rotate-180 transition-transform">↓</span>
            </summary>
            <div class="pt-4 text-sm text-mute">
              Worldwide shipping available. Due to the natural nature of our products, we offer returns within 14 days if the seal is unbroken.
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { addToCart } from '../../store/cart.js';

  const addBtn = document.getElementById('add-to-cart-large');
  const buyBtn = document.getElementById('buy-now');

  addBtn?.addEventListener('click', () => {
    const product = JSON.parse(addBtn.getAttribute('data-product') || '{}');
    addToCart(product);
    alert(`${product.name} added to cart!`);
  });

  buyBtn?.addEventListener('click', () => {
    const product = JSON.parse(buyBtn.getAttribute('data-product') || '{}');
    addToCart(product);
    window.location.href = '/cart';
  });
</script>
